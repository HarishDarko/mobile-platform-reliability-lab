<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage async="false" continueOnError="false" enabled="true" name="Add-Proxy-Headers">
  <DisplayName>Add Proxy Headers</DisplayName>
  <Set>
    <Headers>
      <Header name="x-api-platform">apigee-demo-proxy</Header>
      <Header name="x-proxy-basepath">/mobile/v1</Header>
    </Headers>
  </Set>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
  <AssignTo createNew="false" transport="http" type="request"/>
</AssignMessage>
